<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.skewmar.knowledgegraph</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>REPO_PATH/scripts/watch.py</string>
        <string>--fetch</string>
    </array>

    <key>WorkingDirectory</key>
    <string>REPO_PATH</string>

    <key>StandardOutPath</key>
    <string>REPO_PATH/launchagent/watch.log</string>

    <key>StandardErrorPath</key>
    <string>REPO_PATH/launchagent/watch.error.log</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>ThrottleInterval</key>
    <integer>30</integer>
</dict>
</plist>
